# Anthropic — powers the classifier + draft nodes
ANTHROPIC_API_KEY=

# LangSmith — tracing + evals (free Developer tier: smith.langchain.com)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=issuegraph

# Optional: raises GitHub API rate limits when fetching issues (public repos work without it)
GITHUB_TOKEN=
